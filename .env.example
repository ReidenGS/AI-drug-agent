# Storage mode: "local" (dev, writes to ./.localstore) or "s3"
STORAGE_MODE=local
LOCAL_STORAGE_ROOT=./.localstore

# Queue mode: "memory" (dev) or "sqs"
QUEUE_MODE=memory

# AWS / S3
AWS_REGION=us-east-1
S3_BUCKET=synagentics-adc-pilot
S3_PREFIX=adc_pilot

# DynamoDB
DDB_TABLE=synagentics-adc-runs

# SQS (only when QUEUE_MODE=sqs)
SQS_QUEUE_URL=

# LLM provider — production Compose requires an explicit choice: "mock"
# (discovery-only/dev), "gemini", "openai", or "qwen". There is no Compose
# default. Having a provider API key set is NOT enough on its own.
# Case-insensitive: Mock / MOCK / mock, Gemini / GEMINI / gemini, OpenAI, and QWEN all work.
LLM_PROVIDER=
GEMINI_API_KEY=
# Default updated 2026-06: gemini-1.5-pro returns 404 unavailable on many new
# keys. gemini-3.5-flash is the most broadly available model right now.
# If you hit `404 model unavailable`, swap in a model your account exposes.
GEMINI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ToolUniverse-backed NVIDIA NIM tools (Step 8/9); leave empty unless testing live NIM calls.
NVIDIA_API_KEY=
# ToolUniverse-backed EvolutionaryScale ESM tools (Step 9); token from
# https://forge.evolutionaryscale.ai. Leave empty unless testing live ESM calls.
ESM_API_KEY=
# Outer timeout for one ToolUniverse-backed live tool call. Increase for long NvidiaNIM tests.
TOOLUNIVERSE_LIVE_CALL_TIMEOUT=60
# Long-running NvidiaNIM complex prediction tools (alphafold/multimer/openfold/boltz)
# benefit from a separate larger timeout.
NVIDIA_NIM_LIVE_CALL_TIMEOUT=1800

# Auth (MVP: simple API key)
API_KEY=dev-key

# Tool inventory source (xlsx path, used by import script)
TOOL_INVENTORY_XLSX=../project_files/ToolUniversity_inventory_v0.2.xlsx

# Production Compose requires an explicit choice. false is appropriate only for
# offline/discovery-only checks that do not execute worker business tasks.
MCP_LIVE_TOOLS=

# Step 1 multipart upload limits — server-side enforcement, do NOT rely on
# frontend validation. Defaults: 10 files per run, 50 MiB per file.
MAX_UPLOAD_FILES_PER_RUN=10
MAX_UPLOAD_BYTES_PER_FILE=52428800

# ── Multi-Agent A2A worker discovery (Turn D) ──────────────────────────────
# Docker-internal service URLs the Orchestrator uses to DISCOVER each worker
# over HTTP A2A. Discovery only runs when WorkerDiscoveryService.discover_for_run
# is called — never at app import/startup. No secrets here.
STEP5_WORKER_URL=http://step5-worker:8005
STEP6_WORKER_URL=http://step6-worker:8006
STRUCTURE_WORKER_URL=http://structure-worker:8009
# Production network timeouts (seconds) for AgentCard discovery + health probes.
# Must be > 0.
A2A_DISCOVERY_TIMEOUT_SECONDS=5.0
A2A_HEALTH_TIMEOUT_SECONDS=5.0

# ── Multi-Agent A2A Docker Compose deployment (Turn E) ─────────────────────
# Host port for the orchestrator/backend service. It is the ONLY business
# service mapped to the host; the three workers stay internal-only.
# Verify this is free on the target host before deploying (do not assume).
ORCHESTRATOR_HOST_PORT=18080
ORCHESTRATOR_MAX_WORKER_RETRIES=3
# Required by the production Orchestrator checkpoint runtime. Use a dedicated
# database or credentials/search_path isolated from Dify/RAGFlow. Never commit
# a real URL or password. There is no SQLite/InMemory production fallback.
LANGGRAPH_CHECKPOINT_DATABASE_URL=
# Finite connection + migration/setup budget. Startup fails closed on expiry.
LANGGRAPH_CHECKPOINT_STARTUP_TIMEOUT_SECONDS=30.0
# Worker bind host/port INSIDE the container (advertised URLs stay the Docker
# DNS names http://step5-worker:8005 etc.). Do not change unless the compose
# service ports change too.
WORKER_BIND_HOST=0.0.0.0
# Shared local-storage root mounted into every business container (Turn E uses a
# single named volume so all four services see the same run artifacts).
LOCAL_STORAGE_ROOT=/data/localstore
